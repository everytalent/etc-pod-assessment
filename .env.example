# Public Supabase (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string used by Drizzle migrations & seed.
# In Supabase: Project Settings → Database → Connection string → "URI" (use the
# pooler URL on port 6543 for serverless; direct on 5432 for local).
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
