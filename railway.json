{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"]
    },
    "buildCommand": "pnpm install --frozen-lockfile --prod=false"
  },
  "deploy": {
    "startCommand": "pnpm worker",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1
  }
}
